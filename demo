    <style>
        :root {
            /* 4月のスプリングカラーテーマ（桜と若葉） */
            --primary-color: #d17a86; /* コーラルピンク / 桜色 */
            --secondary-color: #e0aeb6; /* 薄いピンク */
            --accent-color: #8da372; /* 若葉色 / スプリンググリーン */
            --bg-color: #fff9fa; /* ほんのりピンクがかったオフホワイト */
            --text-color: #4a3e40; /* 濃いブラウン（黒より柔らかい印象） */
            --highlight-color: #f29c9c; /* ポップなアクセントピンク */
            --shadow: 0 10px 30px rgba(209, 122, 134, 0.15);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Noto Sans JP', sans-serif;
            background-color: #f0e9ea; /* 背景も春らしく明るいグレーピンクに */
            color: var(--text-color);
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            padding: 20px 10px;
            line-height: 1.7;
        }

        /* Paper Flyer Container */
        .flyer-container {
            width: 100%;
            max-width: 600px;
            background-color: var(--bg-color);
            box-shadow: var(--shadow);
            position: relative;
            overflow: hidden;
            border-radius: 2px;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Paper Texture Effect */
        .flyer-container::before {
            content: "";
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: url("data:image/svg+xml,%3Csvg width='150' height='150' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
            opacity: 0.3; /* 春らしく少しテクスチャを薄めに */
            pointer-events: none;
            z-index: 2;
        }

        .content-wrapper {
            position: relative;
            z-index: 3;
            padding: 50px 40px;
        }

        /* Header Design */
        header {
            text-align: center;
            border-bottom: 2px dashed var(--secondary-color);
            padding-bottom: 25px;
            margin-bottom: 35px;
        }

        .subtitle {
            font-size: 0.95rem;
            letter-spacing: 0.15em;
            margin-bottom: 12px;
            color: var(--secondary-color);
            font-weight: 700;
            text-transform: uppercase;
        }

        h1 {
            font-family: 'Zen Maru Gothic', sans-serif;
            font-size: 2.8rem;
            color: var(--primary-color);
            margin-bottom: 20px;
            line-height: 1.1;
        }

        .vol-badge {
            display: inline-block;
            font-size: 0.55em;
            background-color: var(--primary-color);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            vertical-align: middle;
            margin-left: 8px;
            transform: translateY(-2px);
        }

        .date-box {
            background-color: var(--primary-color);
            color: white;
            display: inline-block;
            padding: 12px 30px;
            font-size: 1.4rem;
            font-weight: 700;
            border-radius: 4px;
            margin: 15px 0;
            letter-spacing: 0.05em;
            box-shadow: 0 4px 10px rgba(209, 122, 134, 0.3);
        }

        .venue-info {
            margin-top: 15px;
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--text-color);
        }

        .price-tag {
            display: inline-block;
            background-color: var(--highlight-color);
            color: white;
            padding: 6px 20px;
            border-radius: 4px;
            font-weight: 700;
            transform: rotate(-3deg);
            box-shadow: 3px 3px 0px rgba(0,0,0,0.05);
            margin-top: 20px;
            font-size: 1.1rem;
        }

        /* Info Section */
        .status-box {
            text-align: center;
            margin-bottom: 40px;
            /* 若葉色をベースにした背景色 */
            background-color: rgba(141, 163, 114, 0.1);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid rgba(141, 163, 114, 0.2);
        }
        
        .start-time {
            font-size: 1.2rem;
            color: var(--accent-color);
            font-weight: 700;
        }

        .status-note {
            font-size: 0.85rem;
            color: #666;
            margin-top: 10px;
            line-height: 1.5;
        }

        /* Timetable */
        .timetable {
            margin-bottom: 45px;
        }

        .section-title {
            font-family: 'Zen Maru Gothic', sans-serif;
            text-align: center;
            color: var(--primary-color);
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        .section-title::before, .section-title::after {
            content: "";
            height: 2px;
            background: var(--accent-color);
            flex-grow: 1;
        }

        .act-item {
            display: flex;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px dotted #e0c8cb;
            transition: background-color 0.3s;
        }

        .act-time {
            font-weight: 700;
            min-width: 110px;
            color: var(--primary-color);
            font-family: 'Roboto', sans-serif;
            font-size: 1.05rem;
        }

        .act-name {
            font-weight: 700;
            font-size: 1.15rem;
            flex-grow: 1;
        }

        .break-item {
            background-color: rgba(141, 163, 114, 0.08);
            padding: 10px;
            border-radius: 6px;
            color: var(--accent-color);
            font-size: 0.95rem;
            margin: 15px 0;
            text-align: center;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-weight: 700;
        }

        .end-marker {
            text-align: center;
            margin-top: 25px;
            color: var(--secondary-color);
            font-size: 0.9rem;
            letter-spacing: 0.2em;
        }

        /* Open Mic Section */
        .open-mic-card {
            background-color: var(--primary-color);
            color: white;
            padding: 30px 25px;
            border-radius: 12px;
            margin-bottom: 40px;
            text-align: center;
            position: relative;
            box-shadow: 0 10px 20px rgba(209, 122, 134, 0.25);
        }

        .open-mic-card h3 {
            font-family: 'Zen Maru Gothic', sans-serif;
            font-size: 1.6rem;
            margin-bottom: 15px;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .open-mic-time {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .order-info {
            font-size: 1rem;
            color: var(--text-color);
            background-color: rgba(255,255,255,0.85);
            font-weight: 700;
            display: inline-block;
            padding: 4px 15px;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        .open-mic-footer {
            font-size: 0.9rem;
            background-color: rgba(255,255,255,0.15);
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            line-height: 1.6;
        }

        /* Footer Access */
        footer {
            text-align: center;
            border-top: 2px dashed var(--secondary-color);
            padding-top: 35px;
        }

        .location-name {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 5px;
            color: var(--primary-color);
        }

        .address {
            font-size: 0.95rem;
            color: #777;
            margin-bottom: 12px;
        }

        .web-link {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 700;
            font-size: 1rem;
            border-bottom: 1px solid transparent;
            transition: border-color 0.3s;
        }
        
        .web-link:hover {
            border-color: var(--accent-color);
        }

        .social-links {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 25px;
        }

        .social-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--text-color);
            text-decoration: none;
            padding: 8px 12px;
            border-radius: 6px;
            background: rgba(0,0,0,0.03);
            transition: all 0.2s;
        }

        .social-btn:hover {
            background: rgba(209, 122, 134, 0.1);
            color: var(--primary-color);
            transform: translateY(-2px);
        }

        /* Utilities */
        .btn-print {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: white;
            border: none;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            box-shadow: 0 4px 15px rgba(209, 122, 134, 0.3);
            cursor: pointer;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-color);
            font-size: 1.2rem;
            transition: transform 0.2s;
        }

        .btn-print:hover {
            transform: scale(1.1);
        }

        /* Mobile Responsive */
        @media (max-width: 500px) {
            body {
                padding: 0;
            }
            .flyer-container {
                box-shadow: none;
                border-radius: 0;
            }
            .content-wrapper {
                padding: 40px 20px;
            }
            h1 {
                font-size: 2.2rem;
            }
            .act-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 4px;
                padding: 12px 0;
            }
            .act-time {
                min-width: auto;
                font-size: 0.9rem;
            }
            .act-name {
                font-size: 1.1rem;
            }
            .social-links {
                flex-direction: column;
                align-items: center;
                gap: 10px;
            }
        }

        @media print {
            .btn-print { display: none; }
            body { background: white; padding: 0; }
            .flyer-container { box-shadow: none; }
        }
    </style>
</head>
